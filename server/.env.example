# ── Required ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
CLIENT_ORIGIN=http://localhost:5173
SERVER_ORIGIN=http://localhost:8000
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/cineworld
JWT_SECRET=change-me-to-at-least-32-random-characters
TMDB_TOKEN=your-tmdb-read-access-token

# ── AI Features (optional — AI endpoints disabled if absent) ──────────────────
GROQ_API_KEY=gsk_...

# ── Redis Cache (optional — falls back to in-memory if absent) ────────────────
REDIS_URL=redis://localhost:6379

# ── Error Monitoring (optional) ───────────────────────────────────────────────
SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Google OAuth (optional — /api/auth/google disabled if absent) ─────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email / SMTP (optional — emails logged to console in dev) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CineWorld" <your@gmail.com>
