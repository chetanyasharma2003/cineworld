{
  "name": "cineworld",
  "version": "1.0.0",
  "private": true,
  "description": "CineWorld full-stack movie discovery app",
  "scripts": {
    "dev": "sh -c 'npm --prefix server run dev & npm --prefix client run dev; wait'",
    "start": "npm --prefix server start",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server start",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:lint": "npm --prefix client run lint",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "test": "npm --prefix server test"
  },
  "engines": {
    "node": ">=18.18"
  }
}
